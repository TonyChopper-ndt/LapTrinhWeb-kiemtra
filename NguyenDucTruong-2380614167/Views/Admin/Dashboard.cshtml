@{
    ViewData["Title"] = "Bảng thống kê";
    int totalCourses = Convert.ToInt32(ViewBag.TotalCourses ?? 0);
    int totalStudents = Convert.ToInt32(ViewBag.TotalStudents ?? 0);
    int totalEnrollments = Convert.ToInt32(ViewBag.TotalEnrollments ?? 0);
    int totalAll = Math.Max(totalCourses + totalStudents + totalEnrollments, 1);
    int coursePercent = totalCourses * 100 / totalAll;
    int studentPercent = totalStudents * 100 / totalAll;
    int enrollmentPercent = 100 - coursePercent - studentPercent;
    int maxValue = Math.Max(1, Math.Max(totalCourses, Math.Max(totalStudents, totalEnrollments)));
    int courseBar = Math.Max(8, totalCourses * 100 / maxValue);
    int studentBar = Math.Max(8, totalStudents * 100 / maxValue);
    int enrollmentBar = Math.Max(8, totalEnrollments * 100 / maxValue);
}

<h2>Bảng thống kê</h2>

<style>
    .dashboard-summary {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
        margin: 24px 0;
    }

    .summary-box {
        min-height: 130px;
        border: 1px solid #d8dee6;
        border-radius: 8px;
        background-color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }

    .summary-box strong {
        font-size: 38px;
        color: #0d6efd;
        line-height: 1;
    }

    .summary-box span {
        margin-top: 10px;
        font-weight: 600;
    }

    .chart-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 22px;
        margin-top: 20px;
    }

    .chart-box {
        border: 1px solid #d8dee6;
        border-radius: 8px;
        background-color: #ffffff;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }

    .chart-title {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .pie-chart {
        width: 220px;
        height: 220px;
        margin: 0 auto 18px;
        border-radius: 50%;
        background: conic-gradient(
            #0d6efd 0 @coursePercent%,
            #198754 @coursePercent% @(coursePercent + studentPercent)%,
            #ffc107 @(coursePercent + studentPercent)% 100%
        );
        position: relative;
    }

    .pie-chart::after {
        content: "";
        position: absolute;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background-color: #ffffff;
        top: 50px;
        left: 50px;
    }

    .legend {
        display: grid;
        gap: 8px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .legend-color {
        width: 16px;
        height: 16px;
        border-radius: 3px;
        display: inline-block;
    }

    .bar-chart {
        height: 250px;
        display: flex;
        align-items: end;
        justify-content: center;
        gap: 34px;
        border-bottom: 2px solid #d8dee6;
        padding: 10px 20px 0;
    }

    .bar-item {
        width: 90px;
        text-align: center;
    }

    .bar {
        width: 70px;
        margin: 0 auto 10px;
        border-radius: 8px 8px 0 0;
        color: #ffffff;
        font-weight: 700;
        display: flex;
        align-items: start;
        justify-content: center;
        padding-top: 8px;
    }

    .bar-name {
        font-weight: 600;
        font-size: 14px;
    }

    @@media (max-width: 768px) {
        .dashboard-summary,
        .chart-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="dashboard-summary">
    <div class="summary-box">
        <strong>@totalCourses</strong>
        <span>Tổng số học phần</span>
    </div>
    <div class="summary-box">
        <strong>@totalStudents</strong>
        <span>Tổng số sinh viên</span>
    </div>
    <div class="summary-box">
        <strong>@totalEnrollments</strong>
        <span>Tổng số lượt đăng ký</span>
    </div>
</div>

<div class="chart-grid">
    <div class="chart-box">
        <div class="chart-title">Biểu đồ tròn</div>
        <div class="pie-chart"></div>

        <div class="legend">
            <div class="legend-item">
                <span class="legend-color" style="background-color:#0d6efd"></span>
                Học phần: @coursePercent%
            </div>
            <div class="legend-item">
                <span class="legend-color" style="background-color:#198754"></span>
                Sinh viên: @studentPercent%
            </div>
            <div class="legend-item">
                <span class="legend-color" style="background-color:#ffc107"></span>
                Lượt đăng ký: @enrollmentPercent%
            </div>
        </div>
    </div>

    <div class="chart-box">
        <div class="chart-title">Biểu đồ cột</div>
        <div class="bar-chart">
            <div class="bar-item">
                <div class="bar" style="height:@courseBar%;background-color:#0d6efd">@totalCourses</div>
                <div class="bar-name">Học phần</div>
            </div>
            <div class="bar-item">
                <div class="bar" style="height:@studentBar%;background-color:#198754">@totalStudents</div>
                <div class="bar-name">Sinh viên</div>
            </div>
            <div class="bar-item">
                <div class="bar" style="height:@enrollmentBar%;background-color:#ffc107;color:#212529">@totalEnrollments</div>
                <div class="bar-name">Đăng ký</div>
            </div>
        </div>
    </div>
</div>
