@model Course

@{
    ViewData["Title"] = "Xóa học phần";
}

<h2>Xóa học phần</h2>

<h4>Bạn có chắc muốn xóa học phần này?</h4>

<dl class="row">
    <dt class="col-sm-2">Tên học phần</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Số tín chỉ</dt>
    <dd class="col-sm-10">@Model.Credits</dd>
    <dt class="col-sm-2">Giảng viên</dt>
    <dd class="col-sm-10">@Model.Lecturer</dd>
</dl>

<form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Courses" class="btn btn-secondary">Quay lại</a>
</form>
